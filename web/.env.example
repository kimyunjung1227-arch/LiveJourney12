# =============================================================================
# LiveJourney 웹 (Vite) — 이 파일을 복사해 web/.env 로 저장한 뒤 값만 채우세요.
#   copy .env.example .env   (Windows PowerShell: Copy-Item .env.example .env)
# =============================================================================

# -----------------------------------------------------------------------------
# 카카오맵 — JavaScript 키
# -----------------------------------------------------------------------------
# 용도: 카카오맵 스크립트 로드, Geocoder.coord2Address(좌표 → 주소·행정구역·건물명)
# 발급: https://developers.kakao.com > 내 애플리케이션 > 앱 키 > JavaScript 키
# 설정: 플랫폼에 웹 도메인(로컬은 http://localhost:5173 등) 등록
# -----------------------------------------------------------------------------
VITE_KAKAO_MAP_API_KEY=

# -----------------------------------------------------------------------------
# 카카오 로컬 — REST API 키  (JavaScript 키와는 별도)
# -----------------------------------------------------------------------------
# 용도: 업로드 "위치" 버튼 시 GPS 주변 장소명(POI) — 공원·관광지·상호 등
#       dapi.kakao.com/v2/local/search/category.json (KakaoAK 헤더)
# 없으면: coord2Address 결과(시·군·구·동, 건물명)만 사용되고 POI 단계는 생략됨
# 발급: 동일 콘솔 > 앱 키 > REST API 키
# -----------------------------------------------------------------------------
VITE_KAKAO_REST_API_KEY=

# (선택) 백엔드 API 베이스 URL — 프로젝트에서 쓰는 경우에만
# VITE_API_URL=

# (선택) Supabase — 기존에 쓰는 경우
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
