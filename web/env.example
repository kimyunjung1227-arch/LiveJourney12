# Vercel / GitHub Actions 빌드 시 Secrets·Variables

# Supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Storage 이미지 리사이즈(빠른 로딩) — Supabase Image Transform 사용 가능한 프로젝트만 true
# VITE_SUPABASE_IMAGE_TRANSFORM=true

# 카카오맵
VITE_KAKAO_MAP_API_KEY=

# (선택) 별도 Node 프록시·레거시 API만 쓸 때 — 기본은 Supabase만 사용
# VITE_API_URL=https://example.com/api
# CI 자동: VITE_BASE_URL=/LiveJourney12/, VITE_SITE_URL=https://kimyunjung1227-arch.github.io/LiveJourney12
# 기상청: Supabase Edge `kma-ultra-ncst` 시크릿(KMA_API_KEY 등) — `weather.js` 참고

# 로컬
# VITE_API_URL=http://localhost:5000/api
