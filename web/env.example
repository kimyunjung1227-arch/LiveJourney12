# Vercel(또는 다른 호스팅) 배포 시 Environment Variables에 아래 이름으로 추가하세요.
# 값은 비워두지 말고 실제 키를 넣습니다.

# Supabase (필수)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 카카오맵 (지도)
VITE_KAKAO_MAP_API_KEY=

# 기상청 API (날씨) — 공공데이터포털 https://www.data.go.kr 에서 "기상청_초단기실황" API 신청 후 발급
VITE_KMA_API_KEY=

# 백엔드 API 베이스 (비우면: 로컬 개발은 Vite가 /api → localhost:5000 프록시, 프로덕션은 현재 사이트 origin + /api)
# 날씨 프록시(KMA)는 백엔드에 KMA_API_KEY 필요 — 루트에서 npm run dev 로 프론트+백 동시 실행 권장
# VITE_API_URL=https://your-api.example.com
