# Vercel(또는 다른 호스팅) 배포 시 Environment Variables에 아래 이름으로 추가하세요.
# 값은 비워두지 말고 실제 키를 넣습니다.

# Supabase (필수)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 카카오맵 (지도)
VITE_KAKAO_MAP_API_KEY=

# 기상청 날씨: VITE_SUPABASE_URL 이 있으면 Edge Function `kma-ultra-ncst` 사용 (Supabase Secrets에 KMA_API_KEY).
# 로컬만 Node 백엔드 쓸 때: backend/.env 의 KMA_API_KEY + npm run dev (Vite가 /api 프록시).

# 백엔드 API (axios: 업로드 등). 비우면 로컬은 Vite /api 프록시, 프로덕션은 도메인별 apiBase.js 규칙
# VITE_API_URL=https://your-node-backend.example.com/api
